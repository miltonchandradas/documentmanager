{
  "name": "documentmanager",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9.9.1"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "dummy"
      },
      "CALM_SD": {
        "kind": "odata",
        "model": "srv/external/CALM_SD",
        "[development]": {
          "credentials": {
            "destination": "CALM_API",
            "path": "/api/calm-documents/v1",
            "headers": {
              "APIKey": "Mwzfn3Azv6Vz0bUQOnEX0S9f08kQrM8V"
            }
          }
        },
        "[production]": {
          "credentials": {
            "destination": "CALM_API",
            "path": "/api/calm-documents/v1"
          }
        }
      }
    }
  },
  "private": true
}
