<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Authorization.V1.xml">
    <edmx:Include Alias="Authorization" Namespace="Org.OData.Authorization.V1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Capabilities.V1.xml">
    <edmx:Include Alias="Capabilities" Namespace="Org.OData.Capabilities.V1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
    <edmx:Include Alias="Common" Namespace="com.sap.vocabularies.Common.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Core.V1.xml">
    <edmx:Include Alias="Core" Namespace="Org.OData.Core.V1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/PersonalData.xml">
    <edmx:Include Alias="PersonalData" Namespace="com.sap.vocabularies.PersonalData.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
    <edmx:Include Alias="UI" Namespace="com.sap.vocabularies.UI.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Validation.V1.xml">
    <edmx:Include Alias="Validation" Namespace="Org.OData.Validation.V1"/>
  </edmx:Reference>
  <edmx:DataServices>
    <Schema Namespace="api.v1.DocumentAPI" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <Annotation Term="Core.Links">
        <Collection>
          <Record>
            <PropertyValue Property="rel" String="author"/>
            <PropertyValue Property="href" String="https://cap.cloud.sap"/>
          </Record>
        </Collection>
      </Annotation>
      <EntityContainer Name="EntityContainer">
        <EntitySet Name="Documents" EntityType="api.v1.DocumentAPI.Documents">
          <NavigationPropertyBinding Path="toStatus" Target="DocumentStatus"/>
          <NavigationPropertyBinding Path="toPriority" Target="DocumentPriorities"/>
          <NavigationPropertyBinding Path="toSource" Target="DocumentSources"/>
          <NavigationPropertyBinding Path="toDocumentType" Target="DocumentTypes"/>
          <NavigationPropertyBinding Path="toURLReferences" Target="URLReferences"/>
          <NavigationPropertyBinding Path="toSolutionProcessAssignments" Target="SolutionProcessAssignments"/>
          <NavigationPropertyBinding Path="toProcessHierarchyAssignments" Target="ProcessHierarchyAssignments"/>
          <NavigationPropertyBinding Path="toTaskAssignments" Target="TaskAssignments"/>
          <NavigationPropertyBinding Path="toLibraryAssignments" Target="LibraryAssignments"/>
          <NavigationPropertyBinding Path="toTestCaseAssignments" Target="TestCaseAssignments"/>
          <NavigationPropertyBinding Path="toExternalFiles" Target="ExternalFiles"/>
          <NavigationPropertyBinding Path="toExternalReferences" Target="ExternalReferences"/>
          <NavigationPropertyBinding Path="toState" Target="DocumentStates"/>
          <NavigationPropertyBinding Path="toApproval" Target="DocumentApprovalStates"/>
        </EntitySet>
        <EntitySet Name="URLReferences" EntityType="api.v1.DocumentAPI.URLReferences">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="SolutionProcessAssignments" EntityType="api.v1.DocumentAPI.SolutionProcessAssignments">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="ProcessHierarchyAssignments" EntityType="api.v1.DocumentAPI.ProcessHierarchyAssignments">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="TaskAssignments" EntityType="api.v1.DocumentAPI.TaskAssignments">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="LibraryAssignments" EntityType="api.v1.DocumentAPI.LibraryAssignments">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="TestCaseAssignments" EntityType="api.v1.DocumentAPI.TestCaseAssignments">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="DocumentStatus" EntityType="api.v1.DocumentAPI.DocumentStatus"/>
        <EntitySet Name="DocumentPriorities" EntityType="api.v1.DocumentAPI.DocumentPriorities"/>
        <EntitySet Name="DocumentTypes" EntityType="api.v1.DocumentAPI.DocumentTypes"/>
        <EntitySet Name="DocumentSources" EntityType="api.v1.DocumentAPI.DocumentSources"/>
        <EntitySet Name="ExternalFiles" EntityType="api.v1.DocumentAPI.ExternalFiles">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <Singleton Name="DmsConfig" Type="api.v1.DocumentAPI.DmsConfig"/>
        <EntitySet Name="ExternalReferences" EntityType="api.v1.DocumentAPI.ExternalReferences">
          <NavigationPropertyBinding Path="parent" Target="Documents"/>
        </EntitySet>
        <EntitySet Name="DocumentApprovalStates" EntityType="api.v1.DocumentAPI.DocumentApprovalStates"/>
        <EntitySet Name="DocumentStates" EntityType="api.v1.DocumentAPI.DocumentStates"/>
        <ActionImport Name="updateTags" Action="api.v1.DocumentAPI.updateTags"/>
      </EntityContainer>
      <EntityType Name="Documents">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <Property Name="displayId" Type="Edm.String" MaxLength="40"/>
        <Property Name="title" Type="Edm.String" MaxLength="255"/>
        <Property Name="content" Type="Edm.String"/>
        <Property Name="projectId" Type="Edm.Guid"/>
        <Property Name="scopeId" Type="Edm.Guid"/>
        <Property Name="statusCode" Type="Edm.Int32" DefaultValue="10"/>
        <Property Name="priorityCode" Type="Edm.Int32" DefaultValue="30"/>
        <Property Name="sourceCode" Type="Edm.String" MaxLength="10" DefaultValue="MANUAL"/>
        <Property Name="documentTypeCode" Type="Edm.String" MaxLength="40" DefaultValue="NA"/>
        <Property Name="createdAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="modifiedAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="tags" Type="Collection(Edm.String)" Nullable="true"/>
        <Property Name="isTemplate" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="ownerId" Type="Edm.String" MaxLength="255"/>
        <Property Name="responsibleId" Type="Edm.String" MaxLength="255"/>
        <Property Name="stateCode" Type="Edm.String" MaxLength="10" DefaultValue="ACT"/>
        <Property Name="approvalCode" Type="Edm.String" MaxLength="20" DefaultValue="NO_APPR_REQ"/>
        <Property Name="fileContent" Type="Edm.Stream"/>
        <NavigationProperty Name="toStatus" Type="api.v1.DocumentAPI.DocumentStatus">
          <ReferentialConstraint Property="statusCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <NavigationProperty Name="toPriority" Type="api.v1.DocumentAPI.DocumentPriorities">
          <ReferentialConstraint Property="priorityCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <NavigationProperty Name="toSource" Type="api.v1.DocumentAPI.DocumentSources">
          <ReferentialConstraint Property="sourceCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <NavigationProperty Name="toDocumentType" Type="api.v1.DocumentAPI.DocumentTypes">
          <ReferentialConstraint Property="documentTypeCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <NavigationProperty Name="toURLReferences" Type="Collection(api.v1.DocumentAPI.URLReferences)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toSolutionProcessAssignments" Type="Collection(api.v1.DocumentAPI.SolutionProcessAssignments)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toProcessHierarchyAssignments" Type="Collection(api.v1.DocumentAPI.ProcessHierarchyAssignments)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toTaskAssignments" Type="Collection(api.v1.DocumentAPI.TaskAssignments)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toLibraryAssignments" Type="Collection(api.v1.DocumentAPI.LibraryAssignments)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toTestCaseAssignments" Type="Collection(api.v1.DocumentAPI.TestCaseAssignments)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toExternalFiles" Type="Collection(api.v1.DocumentAPI.ExternalFiles)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toExternalReferences" Type="Collection(api.v1.DocumentAPI.ExternalReferences)" Partner="parent">
          <OnDelete Action="Cascade"/>
        </NavigationProperty>
        <NavigationProperty Name="toState" Type="api.v1.DocumentAPI.DocumentStates">
          <ReferentialConstraint Property="stateCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <NavigationProperty Name="toApproval" Type="api.v1.DocumentAPI.DocumentApprovalStates">
          <ReferentialConstraint Property="approvalCode" ReferencedProperty="code"/>
        </NavigationProperty>
        <Property Name="version" Type="Edm.Int32" DefaultValue="1"/>
        <Property Name="isLatest" Type="Edm.Boolean" DefaultValue="true"/>
      </EntityType>
      <EntityType Name="URLReferences">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toURLReferences">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="name" Type="Edm.String" MaxLength="255" Nullable="false"/>
        <Property Name="url" Type="Edm.String" MaxLength="1000" Nullable="false"/>
      </EntityType>
      <EntityType Name="SolutionProcessAssignments">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toSolutionProcessAssignments">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="solutionProcessId" Type="Edm.String"/>
        <Property Name="scopeId" Type="Edm.Guid"/>
        <Property Name="solutionScenarioId" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="ProcessHierarchyAssignments">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toProcessHierarchyAssignments">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="displayId" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="TaskAssignments">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toTaskAssignments">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="id" Type="Edm.String"/>
        <Property Name="type" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="LibraryAssignments">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toLibraryAssignments">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="libraryUuid" Type="Edm.Guid"/>
        <Property Name="libraryType" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="TestCaseAssignments">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toTestCaseAssignments">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="testCaseUuid" Type="Edm.Guid"/>
        <Property Name="testCaseType" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="DocumentStatus">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.Int32" Nullable="false" DefaultValue="10"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <EntityType Name="DocumentPriorities">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.Int32" Nullable="false" DefaultValue="30"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <EntityType Name="DocumentTypes">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.String" MaxLength="40" Nullable="false" DefaultValue="NA"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <EntityType Name="DocumentSources">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.String" MaxLength="10" Nullable="false" DefaultValue="MANUAL"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <EntityType Name="ExternalFiles">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toExternalFiles">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="fileName" Type="Edm.String"/>
        <Property Name="fileType" Type="Edm.String"/>
        <Property Name="fileSize" Type="Edm.Int32"/>
        <Property Name="fileVersion" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="DmsConfig">
        <Property Name="destinationAvailable" Type="Edm.Boolean" DefaultValue="false"/>
        <Property Name="repositoryId" Type="Edm.String"/>
      </EntityType>
      <EntityType Name="ExternalReferences">
        <Key>
          <PropertyRef Name="uuid"/>
        </Key>
        <Property Name="uuid" Type="Edm.Guid" Nullable="false"/>
        <NavigationProperty Name="parent" Type="api.v1.DocumentAPI.Documents" Partner="toExternalReferences">
          <ReferentialConstraint Property="parent_uuid" ReferencedProperty="uuid"/>
        </NavigationProperty>
        <Property Name="parent_uuid" Type="Edm.Guid"/>
        <Property Name="externalReferenceId" Type="Edm.String" MaxLength="255" Nullable="false"/>
        <Property Name="name" Type="Edm.String" MaxLength="255" Nullable="false"/>
        <Property Name="url" Type="Edm.String" MaxLength="1000"/>
      </EntityType>
      <EntityType Name="DocumentApprovalStates">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.String" MaxLength="20" Nullable="false" DefaultValue="NO_APPR_REQ"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <EntityType Name="DocumentStates">
        <Key>
          <PropertyRef Name="code"/>
        </Key>
        <Property Name="code" Type="Edm.String" MaxLength="10" Nullable="false" DefaultValue="ACT"/>
        <Property Name="name" Type="Edm.String" MaxLength="255"/>
      </EntityType>
      <ComplexType Name="api_v1_TagsAssigned">
        <Property Name="tags" Type="Collection(Edm.String)" Nullable="true"/>
      </ComplexType>
      <Action Name="updateTags" IsBound="false">
        <Parameter Name="documentUUID" Type="Edm.String" Nullable="false"/>
        <Parameter Name="tags" Type="Collection(Edm.String)" Nullable="true"/>
        <ReturnType Type="api.v1.DocumentAPI.api_v1_TagsAssigned"/>
      </Action>
      <Annotation Term="Core.SchemaVersion" String="1.0.4"/>
      <Annotations Target="api.v1.DocumentAPI.EntityContainer">
        <Annotation Term="Common.Label" String="SAP Cloud ALM Documents"/>
        <Annotation Term="Core.Description" String="Allows to create, read, query and delete documents with their related entities."/>
        <Annotation Term="Core.LongDescription" String="The Documents OData API enables you to manage documents and their related entities in SAP Cloud ALM.&lt;p>&#xA;You require the following authorization scopes to access the API:&#xA;&lt;ul>&#xA;&lt;li>calm-api.documents.read: to read document entities.&lt;/li>&#xA;&lt;li>calm-api.documents.write: to write document entities.&lt;/li>&#xA;&lt;li>calm-api.documents.delete: to delete document entities.&lt;/li>&#xA;&lt;/ul>"/>
        <Annotation Term="Capabilities.BatchSupported" Bool="false"/>
        <Annotation Term="Capabilities.KeyAsSegmentSupported" Bool="true"/>
        <Annotation Term="Authorization.SecuritySchemes">
          <Collection>
            <Record Type="Authorization.SecurityScheme">
              <PropertyValue Property="Authorization" String="OAuth2"/>
            </Record>
          </Collection>
        </Annotation>
        <Annotation Term="Authorization.Authorizations">
          <Collection>
            <Record Type="Authorization.OAuth2ClientCredentials">
              <PropertyValue Property="Name" String="OAuth2"/>
              <PropertyValue Property="Description" String="Authentication via OAuth2 with client credentials flow"/>
              <PropertyValue Property="TokenUrl" String="https://{identityzone}.authentication.{region}.hana.ondemand.com/oauth/token"/>
              <PropertyValue Property="Scopes">
                <Collection>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="calm-api.documents.read"/>
                    <PropertyValue Property="Description" String="Read access to documents"/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="calm-api.documents.write"/>
                    <PropertyValue Property="Description" String="Write access to documents"/>
                  </Record>
                  <Record Type="Authorization.AuthorizationScope">
                    <PropertyValue Property="Scope" String="calm-api.documents.delete"/>
                    <PropertyValue Property="Description" String="Delete access to documents"/>
                  </Record>
                </Collection>
              </PropertyValue>
            </Record>
          </Collection>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.updateTags()">
        <Annotation Term="Core.Description" String="Action to assign and unassign tags in a document"/>
        <Annotation Term="Core.LongDescription" String="Already assigned tags remain unchanged, new tags will be assigned. Assigned tags which are not given by the action will be unassigned."/>
        <Annotation Term="Common.Label" String="Document Headers"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.updateTags()/documentUUID">
        <Annotation Term="Core.LongDescription" String="UUID of document"/>
        <Annotation Term="Core.Example">
          <Record Type="Core.PrimitiveExampleValue">
            <PropertyValue Property="Value" String="22222222-2222-2222-2222-222222222222"/>
          </Record>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.updateTags()/tags">
        <Annotation Term="Core.LongDescription" String="Array of tag labels"/>
        <Annotation Term="Core.Example">
          <Record Type="Core.PrimitiveExampleValue">
            <PropertyValue Property="Value" String="Tag Label 1"/>
          </Record>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents">
        <Annotation Term="Core.Description" String="Main entity for Documents including html content"/>
        <Annotation Term="Core.LongDescription" String="Main entity for Documents including html content"/>
        <Annotation Term="Common.Label" String="Document Headers"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.EntityContainer/Documents">
        <Annotation Term="Capabilities.ReadRestrictions">
          <Record Type="Capabilities.ReadRestrictionsType">
            <PropertyValue Property="LongDescription" String="Retrieve a list of documents with its content and other properties. You can use $expand query parameter to read child entities like url references and assigned solution processes."/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.UpdateRestrictions">
          <Record Type="Capabilities.UpdateRestrictionsType">
            <PropertyValue Property="Updatable" Bool="true"/>
            <PropertyValue Property="LongDescription" String="Update an existing document is supported only for attribute 'fileContent' via PUT request."/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.DeleteRestrictions">
          <Record Type="Capabilities.DeleteRestrictionsType">
            <PropertyValue Property="LongDescription" String="Delete a document by its UUID. This is a cascading delete operation which will also delete all child entities like url references and assignments to solution processes or process hierarchy nodes."/>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.InsertRestrictions">
          <Record Type="Capabilities.InsertRestrictionsType">
            <PropertyValue Property="LongDescription" String="Create a new document with its content and other properties. You can also use deep create to assign url references and assignments to solution processes or process hierarchy nodes to the document in one single HTTP request."/>
            <PropertyValue Property="ErrorResponses">
              <Collection>
                <Record Type="Capabilities.HttpResponse">
                  <PropertyValue Property="StatusCode" String="4XX"/>
                  <PropertyValue Property="Description" String="Bad Request - Invalid input data, e.g. missing required properties like title or projectId."/>
                </Record>
              </Collection>
            </PropertyValue>
          </Record>
        </Annotation>
        <Annotation Term="Capabilities.FilterRestrictions">
          <Record Type="Capabilities.FilterRestrictionsType">
            <PropertyValue Property="FilterExpressionRestrictions">
              <Collection>
                <Record Type="Capabilities.FilterExpressionRestrictionType">
                  <PropertyValue Property="Property" PropertyPath="createdAt"/>
                  <PropertyValue Property="AllowedExpressions" String="SingleRange"/>
                </Record>
                <Record Type="Capabilities.FilterExpressionRestrictionType">
                  <PropertyValue Property="Property" PropertyPath="modifiedAt"/>
                  <PropertyValue Property="AllowedExpressions" String="SingleRange"/>
                </Record>
              </Collection>
            </PropertyValue>
          </Record>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/uuid">
        <Annotation Term="Core.Computed" Bool="true"/>
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/displayId">
        <Annotation Term="Core.Computed" Bool="true"/>
        <Annotation Term="Core.LongDescription" String="ID of the document"/>
        <Annotation Term="Core.Example">
          <Record Type="Core.PrimitiveExampleValue">
            <PropertyValue Property="Value" String="7-19"/>
          </Record>
        </Annotation>
        <Annotation Term="Common.Label" String="{i18n>Documents.ID}"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/title">
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Common.Label" String="{i18n>Documents.Title}"/>
        <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/content">
        <Annotation Term="Core.LongDescription" String="Html rich-text content of the document"/>
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Common.TextFormat" EnumMember="Common.TextFormatType/html"/>
        <Annotation Term="Common.Label" String="{i18n>Documents.Content}"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/projectId">
        <Annotation Term="Core.LongDescription" String="UUID of assigned project"/>
        <Annotation Term="Core.Example">
          <Record Type="Core.PrimitiveExampleValue">
            <PropertyValue Property="Value" String="11111111-1111-1111-1111-111111111111"/>
          </Record>
        </Annotation>
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Common.FieldControl" EnumMember="Common.FieldControlType/Mandatory"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/scopeId">
        <Annotation Term="Core.LongDescription" String="UUID of directly assigned scope"/>
        <Annotation Term="Core.Immutable" Bool="true"/>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/statusCode">
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Validation.AllowedValues">
          <Collection>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="InProgress"/>
              <PropertyValue Property="Value" Int="10"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="InReview"/>
              <PropertyValue Property="Value" Int="20"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Released"/>
              <PropertyValue Property="Value" Int="30"/>
            </Record>
          </Collection>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/priorityCode">
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Validation.AllowedValues">
          <Collection>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="VeryHigh"/>
              <PropertyValue Property="Value" Int="10"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="High"/>
              <PropertyValue Property="Value" Int="20"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Medium"/>
              <PropertyValue Property="Value" Int="30"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Low"/>
              <PropertyValue Property="Value" Int="40"/>
            </Record>
          </Collection>
        </Annotation>
      </Annotations>
      <Annotations Target="api.v1.DocumentAPI.Documents/sourceCode">
        <Annotation Term="Core.Immutable" Bool="true"/>
        <Annotation Term="Validation.AllowedValues">
          <Collection>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="ManuallyCreated"/>
              <PropertyValue Property="Value" String="MANUAL"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="External"/>
              <PropertyValue Property="Value" String="EXTERNAL"/>
